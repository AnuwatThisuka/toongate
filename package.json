{
  "name": "toongate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "types": "wrangler types src/worker.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply toongate-savings --local",
    "db:migrate:remote": "wrangler d1 migrations apply toongate-savings --remote"
  },
  "dependencies": {
    "@toon-format/toon": "^2.3.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.80.0"
  }
}
