{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "toongate",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true, "head_sampling_rate": 1 },
  // UPSTREAM_URL is set in .dev.vars (local) or via `wrangler secret put` (production).
  // Default: Cloudflare AI Gateway
  //   https://gateway.ai.cloudflare.com/v1/{account_id}/{gateway_id}/openai
  // Change to any OpenAI-compatible upstream:
  //   https://oai.helicone.ai/v1
  //   https://api.openai.com/v1
  //   https://your-litellm-instance/v1
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "toongate-savings",
      "database_id": "b4358ffb-dab1-429c-b63c-9a0e6907250a",
      "migrations_dir": "migrations",
    },
  ],
}
